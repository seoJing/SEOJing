{
  "extends": "@app/typescript-config/react.json",
  "compilerOptions": {
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "next/font/google": ["./node_modules/vinext/dist/shims/font-google"],
      "next/font/local": ["./node_modules/vinext/dist/shims/font-local"],
      "next/link": ["./node_modules/vinext/dist/shims/link"],
      "next/navigation": ["./node_modules/vinext/dist/shims/navigation"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".vinext/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
